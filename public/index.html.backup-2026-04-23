  if (saved && saved.msgs && saved.msgs.length > 1) {
    messages = saved.msgs;
    userAnswerCount = saved.answerCount || 0;
    for (let i = 1; i < messages.length; i++) {
      const m = messages[i];
      addMsg(m.role === 'assistant' ? 'bot' : 'user', m.content, true);
    }
    updateProgress();
    updateCounter();
    // Nach Restore: Export-Box an letzte bot-Nachricht anhängen wenn passend
    const lastBot = [...messages].reverse().find(m => m.role === 'assistant');
    if (lastBot && shouldShowExport(lastBot.content)) {
      const bubbles = document.querySelectorAll('#chat .message.bot .bubble');
      const lastBubble = bubbles[bubbles.length - 1];
      if (lastBubble && !lastBubble.querySelector('.export-box')) appendExportBox(lastBubble);
    }
  } else {
    messages = [];
    userAnswerCount = 0;
    clearSession(mode);
    updateCounter();
    initChat();
  }
  // Draft für diesen Mode restoren falls vorhanden
  restoreDraft(mode);
}

