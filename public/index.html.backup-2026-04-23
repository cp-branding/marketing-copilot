function buildSystemPrompt(mode, answerCount, profile = null) {
  let prompt;
  if (mode === 'onboarding') prompt = PROMPT_ONBOARDING;
  else if (mode === 'quick') prompt = PROMPT_QUICK;
  else if (mode === 'holistic') prompt = PROMPT_HOLISTIC;
  else prompt = PROMPT_ROAST;

  if (mode === 'roast' && answerCount >= 10) {
    prompt += `\n\nSYSTEM-NOTIZ: Der Nutzer hat jetzt **10 Fragen beantwortet**. Das ist der Hard-Cap. Du MUSST jetzt dein Urteil liefern — einen konkreten Weak Spot, keine weitere Frage mehr, egal was.`;
  }
  if (mode === 'quick' && answerCount >= 5) {
    prompt += `\n\nSYSTEM-NOTIZ: Der Nutzer hat jetzt **5 Fragen beantwortet**. Das ist der Hard-Cap. Du MUSST jetzt die Empfehlung liefern — Domäne + konkrete Einschätzung + eine klare nächste Aktion. Keine weitere Frage.`;
  }
  if (mode === 'onboarding' && answerCount >= 8) {
    prompt += `\n\nSYSTEM-NOTIZ: Der Nutzer hat jetzt **8 Fragen beantwortet**. Du MUSST jetzt den <<<PROFIL>>>-Block produzieren — keine weitere Frage, egal was. Format exakt einhalten.`;
  }

  // Profil aus Onboarding in alle späteren Modi injizieren
  if (mode !== 'onboarding') {
    const p = profile !== null ? profile : getProfile();
    if (p && p.trim()) {
      prompt = `KONTEXT über den Nutzer (aus dem Kennenlern-Check):
${p}

---

**ABSOLUT WICHTIG — so öffnest du diese Session:**

Du kennst diesen Menschen bereits durch den Kontext oben. Deine ERSTE Nachricht MUSS das zeigen. Generische Opener wie "Moin, was ist gerade dein größtes Marketing-Ding?" oder "Was läuft nicht rund?" oder "Beschreib mir deine Marketing-Strategie" sind **verboten** wenn Kontext da ist — das ist faul und zeigt dem User dass du seinen Kontext ignorierst.

Stattdessen exakt das in deiner ersten Nachricht:

1. **Kurze warme Begrüßung** ("Moin.")
2. **Spiegel in 1–2 Sätzen was du über seine Situation schon weißt** — die 2–3 relevantesten Punkte für die jetzige Session. Zum Beispiel: "Du bist solo mit Personal Branding für Interim-Manager unterwegs, läuft über Referenzen, und du willst skalierbare digitale Produkte neben der 1:1-Beratung aufbauen — bisher ohne Marketing-Budget."
3. **Stell dann eine spezifische erste Frage** die genau auf diesen Kontext zugeschnitten ist. Nie "Was ist dein größtes Problem?" wenn du es aus dem Kontext schon eingrenzen kannst — besser: "Was hält dich gerade am meisten davon ab, die digitalen Produkte wirklich in den Markt zu kriegen — Sichtbarkeit, Positionierung dafür, oder etwas ganz anderes?"

**Drei harte Regeln** ab Nachricht 1:
- Niemals Fragen stellen deren Antwort schon im Kontext steht (Branche, Angebot, Zielgruppe, B2B/B2C, Sichtbarkeits-Stand, etc.)
- Niemals generisch eröffnen wenn Kontext da ist
- Der User muss in der ersten Zeile schon merken: "Der hat meine Situation wirklich gelesen"

Wenn in dem eigentlichen Modus-Prompt unten generische Opener-Beispiele stehen ("Moin, was ist gerade dein größtes Marketing-Ding?" etc.) — **ignoriere die**. Die gelten nur wenn KEIN Kontext vorhanden ist. Hier ist Kontext da — also öffnest du spezifisch.

---

${prompt}`;
    }
  }

  return prompt;
}

