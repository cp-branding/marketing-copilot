<script>
// ─── Standalone-Modus erkennen ───────────────────────────────────────────────
const IS_STANDALONE = location.protocol === 'file:';
const API_KEY_STORE = 'ma_anthropic_key';

// Unified localStorage write — silent-fails (Private-Mode/Quota) ohne Throw,
// loggt damit Debug sichtbar ist. Gibt true/false zurück für Call-Sites die reagieren wollen.
function safeSetItem(key, value) {
  try { localStorage.setItem(key, value); return true; }
  catch (e) { console.warn('[storage] write failed for ' + key + ':', e?.message || e); return false; }
}
function safeGetItem(key) {
  try { return localStorage.getItem(key); }
  catch { return null; }
}
function safeRemoveItem(key) {
  try { localStorage.removeItem(key); } catch {}
}

function getApiKey() { return safeGetItem(API_KEY_STORE) || ''; }
function setApiKey(k) { return safeSetItem(API_KEY_STORE, k); }
function clearApiKey() { safeRemoveItem(API_KEY_STORE); }

function maybeStartOnboarding() {
  // Wenn noch kein Profil gespeichert — First-Visit → Onboarding starten
  if (!localStorage.getItem('ma_profile_v1')) {
    // openMode ist u.U. noch nicht definiert wenn Script oben läuft — daher defer
    setTimeout(() => { if (typeof openMode === 'function') openMode('onboarding'); }, 50);
  } else {
    // Profil da → Hero-Line personalisiert animieren
    setTimeout(() => { if (typeof renderHeroLine === 'function') renderHeroLine(); }, 150);
  }
}

// ─── HERO LINE (personalisiert, typewriter-animiert) ────────────────────────
const HERO_GENERIC = [
  'Wie war die Woche?',
  'Moin. Schön dass du wieder da bist.',
];
const HERO_PRINCIPLES = [
  'Emotionale Verbindungen kommen vor dem Verkauf.',
  'Ein gutes Profil zieht mehr an und stößt die Falschen ab.',
  'Branding ist Vertrauen über Zeit durch konsistentes Verhalten.',
  'Menschen kaufen von Menschen.',
  'Wer sich zeigt wie er ist, zieht die richtigen an.',
  'In diesem Leben gibt es keine Abkürzungen.',
];

// Zieht den Kern-Topic aus dem Angebot-Feld (z.B. "1:1 Personal Branding für Interim-Manager" → "Personal Branding")
function heroShortTopic(angebot) {
  if (!angebot) return '';
  let cleaned = angebot.replace(/^[\d:\-\s]+/, '').trim();
  const idx = cleaned.search(/\b(für|von|bei|mit|im|in|als)\b/i);
  if (idx > 0) cleaned = cleaned.substring(0, idx).trim();
  const words = cleaned.split(/\s+/).slice(0, 3).join(' ');
  if (words.length < 3 || words.length > 40) return '';
  return words;
}

// Dativ-Plural für Zielgruppe (best-effort — skipt wenn unsicher)
function heroDativPlural(noun) {
  if (!noun) return null;
  if (/(er|ner|iker|ator|isch)$/i.test(noun)) return noun + 'n';
  if (/in$/i.test(noun)) return noun + 'nen';
  if (/e?s$/i.test(noun)) return noun; // englische Plurale stehen
  return null;
}

function heroExtractZielgruppe(angebot) {
  const m = angebot.match(/für\s+([A-ZÄÖÜ][\wäöüß\-]+)/);
  return m ? m[1] : null;
}

function buildHeroLines(profile) {
  if (!profile) return [...HERO_GENERIC, ...HERO_PRINCIPLES];
  const angebot = (profile.match(/Angebot:\s*(.+)/i)?.[1] || '').trim();
  const pain = (profile.match(/Aktueller Pain:\s*(.+)/i)?.[1] || '').toLowerCase();
  const profileLines = [];

  const topic = heroShortTopic(angebot);
  if (topic) profileLines.push(`Wie läuft's gerade mit deinem ${topic}?`);

  const zgDativ = heroDativPlural(heroExtractZielgruppe(angebot));
  if (zgDativ) profileLines.push(`Wie läuft's mit den ${zgDativ}?`);

  if (pain.includes('digitale produkt')) profileLines.push(`Wie läuft's mit den digitalen Produkten?`);
  if (pain.includes('sichtbarkeit'))     profileLines.push(`Wie läuft's mit deiner Sichtbarkeit?`);
  if (pain.includes('positionier'))      profileLines.push(`Wie läuft's mit deiner Positionierung?`);

  return [...profileLines, ...HERO_GENERIC, ...HERO_PRINCIPLES];
}

const HERO_LAST_KEY = 'ma_hero_last_v1';
function pickHeroLine() {
  const lines = buildHeroLines(getProfile());
  if (!lines.length) return 'Moin.';
  let last = null;
  try { last = sessionStorage.getItem(HERO_LAST_KEY); } catch {}
  const pool = lines.filter(l => l !== last);
  const final = (pool.length ? pool : lines)[Math.floor(Math.random() * (pool.length || lines.length))];
  try { sessionStorage.setItem(HERO_LAST_KEY, final); } catch {}
  return final;
}

async function renderHeroLine() {
  const el = document.getElementById('heroLine');
  if (!el) return;
  const line = pickHeroLine();
  el.textContent = '';
  try { await typewriter(el, line); } catch(e) { el.textContent = line; }
}

if (IS_STANDALONE) {
  if (!getApiKey()) {
    document.addEventListener('DOMContentLoaded', showApiKeySetup);
  } else {
    document.addEventListener('DOMContentLoaded', maybeStartOnboarding);
  }
} else {
  (async () => {
    try {
      const res = await fetch('/api/auth');
      if (!res.ok) { window.location.href = '/login'; return; }
      maybeStartOnboarding();
    } catch { window.location.href = '/login'; }
  })();
}

function showApiKeySetup() {
  const existing = document.getElementById('apiKeyModal');
  if (existing) existing.remove();
  const modal = document.createElement('div');
  modal.id = 'apiKeyModal';
  modal.style.cssText = 'position:fixed;inset:0;z-index:9999;background:rgba(15,20,26,0.85);display:flex;align-items:center;justify-content:center;padding:20px;font-family:var(--cp-font-ui);';
  modal.innerHTML = `
    <div style="background:var(--cp-navy-deep);border:3px solid var(--cp-orange);border-radius:8px;padding:32px 28px;max-width:460px;width:100%;box-shadow:3px 3px 0 #1F1F1F, 6px 6px 0 #E8731F;color:var(--cp-off-white);">
      <div style="font-family:var(--cp-font-display);font-size:14px;color:var(--cp-orange);margin-bottom:10px;letter-spacing:0.04em;">&gt; LOKALER TEST-MODUS</div>
      <div style="font-family:var(--cp-font-ui);font-size:14px;color:#D8DDE2;line-height:1.55;margin-bottom:22px;">Du öffnest die Datei direkt im Browser. Damit der Chat funktioniert, brauche ich einmal deinen <strong style="color:var(--cp-orange);">Anthropic API-Key</strong>. Er wird nur lokal gespeichert.</div>
      <label style="display:block;font-family:var(--cp-font-display);font-size:10px;color:var(--cp-orange);letter-spacing:0.1em;text-transform:uppercase;margin-bottom:8px;">&gt; API-KEY</label>
      <input id="apiKeyInput" type="password" placeholder="sk-ant-..." autofocus style="width:100%;background:var(--cp-off-white);border:2px solid var(--cp-black);border-radius:4px;padding:13px 14px;font-family:var(--cp-font-mono);font-size:16px;color:var(--cp-black);outline:none;box-shadow:2px 2px 0 var(--cp-orange-deep);margin-bottom:14px;"/>
      <div id="apiKeyError" style="display:none;font-family:var(--cp-font-mono);font-size:14px;color:#FF6B6B;margin-bottom:12px;">! Fehler</div>
      <button onclick="saveApiKeyFromInput()" style="width:100%;background:var(--cp-orange);color:var(--cp-black);border:2px solid var(--cp-black);border-radius:4px;padding:13px;font-family:var(--cp-font-display);font-size:12px;letter-spacing:0.08em;text-transform:uppercase;cursor:pointer;box-shadow:2px 2px 0 #1F1F1F, 4px 4px 0 #E8731F;">▶ LOS GEHT'S</button>
      <div style="margin-top:16px;font-family:var(--cp-font-mono);font-size:14px;color:#9AA3AC;text-align:center;line-height:1.5;">Key holen: <a href="https://console.anthropic.com/settings/keys" target="_blank" style="color:var(--cp-orange);text-decoration:none;">console.anthropic.com</a></div>
    </div>`;
  document.body.appendChild(modal);
  const inp = document.getElementById('apiKeyInput');
  inp.addEventListener('keydown', e => { if (e.key === 'Enter') saveApiKeyFromInput(); });
}
function saveApiKeyFromInput() {
  const inp = document.getElementById('apiKeyInput');
  const err = document.getElementById('apiKeyError');
  const val = inp.value.trim();
  if (!val.startsWith('sk-ant-')) {
    err.textContent = '! Das sieht nicht nach einem gültigen Anthropic-Key aus (muss mit sk-ant- starten).';
    err.style.display = 'block';
    return;
  }
  setApiKey(val);
  const modal = document.getElementById('apiKeyModal');
  if (modal) modal.remove();
}

