    exportFileName: 'marketing-90-tage-plan.md',
  },
  roast: {
    label: 'Modus 3',
    title: 'Test',
    tag: 'MODUS 3 · TEST',
    maxQuestions: 10,
    minQuestions: 5,
    showProgress: true,
    exportLabel: 'Weak Spot merken (Markdown)',
    exportFileName: 'test-weak-spot.md',
  },
};

// ─── USER PROFILE (aus Onboarding) ───────────────────────────────────────────
const PROFILE_KEY = 'ma_profile_v1';
function getProfile() { return safeGetItem(PROFILE_KEY) || ''; }
function setProfile(p) { return safeSetItem(PROFILE_KEY, p); }
function clearProfile() { safeRemoveItem(PROFILE_KEY); }

const PROMPT_ONBOARDING = `Du führst den **einmaligen Kennenlern-Check** für Constantins Marketing Co-Pilot durch. Ziel: in **genau 8 Fragen** ein vollständiges Profil bauen, damit alle kommenden Sessions sofort mit Kontext starten.

