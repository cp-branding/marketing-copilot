function typewriterSpeedFor(length) {
  if (length < 200) return 12;   // Onboarding-Frage, kurze Rückfrage
  if (length < 600) return 8;    // kurze Empfehlung
  if (length < 1200) return 5;   // mittel
  return 3;                      // 90-Tage-Plan etc.
}

async function typewriter(el, fullText, speed) {
  if (speed === undefined) speed = typewriterSpeedFor(fullText.length);
  isTyping = true;
  skipType = false;
  el.classList.add('typing');
  el.addEventListener('click', () => { if (isTyping) skipType = true; }, { once: true });

  // strip markdown markers so they don't flash during typing
  const plain = fullText
    .replace(/\*\*(.*?)\*\*/g, '$1')
    .replace(/(?<!\*)\*([^*\n]+?)\*(?!\*)/g, '$1');
  const esc = plain
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;');

  const chat = document.getElementById('chat');
  // Grapheme-Split: Emojis & Surrogate-Pairs als eine Einheit — verhindert Flackern
  const graphemes = typeof Intl !== 'undefined' && Intl.Segmenter
    ? Array.from(new Intl.Segmenter('de', { granularity: 'grapheme' }).segment(esc), s => s.segment)
    : Array.from(esc);
  let acc = '';
  for (let i = 0; i < graphemes.length; i++) {
    if (skipType) break;
    const ch = graphemes[i];
    acc += ch;
    el.innerHTML = acc.replace(/\n/g, '<br>');
    let delay = speed;
    if (ch === ' ') delay = speed * 0.4;
    else if (ch === '\n') delay = speed * 3;
    else if (/[.!?]/.test(ch)) delay = speed * 6;
    else if (/[,:;]/.test(ch)) delay = speed * 2.5;
    await new Promise(r => setTimeout(r, delay));
    if (ch === '\n' || i % 20 === 0) chat.scrollTop = chat.scrollHeight;
  }
  el.innerHTML = formatText(fullText);
  el.classList.remove('typing');
  isTyping = false;
  chat.scrollTop = chat.scrollHeight;
}

function addMsg(role, text, isRestore = false) {
  const chat = document.getElementById('chat');
  const wrap = document.createElement('div');
  wrap.className = 'message ' + role;

  const bubble = document.createElement('div');
  bubble.className = 'bubble';

  wrap.appendChild(bubble);
  chat.appendChild(wrap);

  // Onboarding: extract profile block from bot output, hide it from view
  let visibleText = text;
  let extractedProfile = null;
  if (role === 'bot' && currentMode === 'onboarding') {
    // Tolerant für Whitespace und Markdown-Umhüllung (**<<<PROFIL>>>**)
    const profileRe = /\*?\*?<<<\s*PROFIL\s*>>>\*?\*?([\s\S]*?)\*?\*?<<<\s*END\s*>>>\*?\*?/i;
    const m = text.match(profileRe);
    if (m) {
      extractedProfile = m[1].trim();
      visibleText = text.replace(profileRe, '').trim();
    }
  }

  if (role === 'user' || isRestore) {
    bubble.innerHTML = formatText(visibleText);
  } else {
    setInputEnabled(false);
    typewriter(bubble, visibleText).then(() => {
      if (extractedProfile) {
        setProfile(extractedProfile);
        // Short pause, then finish onboarding
        setTimeout(finishOnboarding, 1200);
        return;
      }
      if (shouldShowExport(visibleText)) appendExportBox(bubble);
      setInputEnabled(true);
      document.getElementById('input')?.focus();
    });
  }

  chat.scrollTop = chat.scrollHeight;
}

function finishOnboarding() {
  // Transition from onboarding chat to the main mode selector
  const chat = document.getElementById('chat');
  const done = document.createElement('div');
  done.className = 'message bot';
  done.innerHTML = '<div class="bubble" style="color:var(--cp-orange);">[ Profil gespeichert · Weiter zur Mode-Auswahl ]</div>';
  chat.appendChild(done);
  chat.scrollTop = chat.scrollHeight;
  setTimeout(() => {
    document.getElementById('chatView').style.display = 'none';
    document.getElementById('selectorView').style.display = 'flex';
    currentMode = null;
    messages = [];
    userAnswerCount = 0;
    clearSession('onboarding');
    updateResumeLinks();
    setInputEnabled(true);
    renderHeroLine();
  }, 1400);
}

function appendExportBox(bubble) {
  // Entferne vorhandene Export-Boxes (nur eine soll aktuell sein — auf der neuesten Antwort)
  document.querySelectorAll('#chat .export-box').forEach(el => el.remove());
  const box = document.createElement('div');
  box.className = 'export-box';
  const heading = currentMode === 'holistic'
    ? '✓ Dein 90-Tage-Plan steht'
    : currentMode === 'roast'
    ? '🔥 Das Urteil'
    : '✓ Deine Notiz';
  box.innerHTML = `<h4>${heading}</h4>
    <div style="display:flex;gap:8px;flex-wrap:wrap;">
      <button class="export-btn primary" onclick="exportCurrent()">⬇ ${MODE_META[currentMode].exportLabel}</button>
      <button class="export-btn" onclick="copyLast()">📋 Kopieren</button>
    </div>`;
  bubble.appendChild(box);
}

function shouldShowExport(text) {
  if (currentMode === 'holistic') {
    return /90-Tage-Marketing-Plan|90-Tage-Plan|Ausgangssituation/i.test(text) && /Diese Woche/i.test(text);
  }
  if (currentMode === 'roast') {
    return userAnswerCount >= 5 && /weak spot|blind spot|schwachpunkt|das urteil|das loch/i.test(text);
  }
  if (currentMode === 'quick') {
    return userAnswerCount >= 2 && (/konkrete nächste aktion|mach heute|mach morgen|konkret heute|nächster schritt/i.test(text) || userAnswerCount >= 5);
  }
  return false;
}

function formatText(text) {
  const esc = text
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;');
  return esc
    // Headings müssen VOR bold/newline-replacement laufen, am Zeilenanfang
    .replace(/^### (.+)$/gm, '<span class="md-h3">$1</span>')
    .replace(/^## (.+)$/gm, '<span class="md-h2">$1</span>')
    .replace(/^# (.+)$/gm, '<span class="md-h1">$1</span>')
    // Bullet-Listen (- Item) und nummerierte Listen (1. Item)
    .replace(/^- (.+)$/gm, '<span class="md-li">$1</span>')
    .replace(/^(\d+)\. (.+)$/gm, '<span class="md-li-num" data-n="$1.">$2</span>')
    .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
    .replace(/(?<!\*)\*([^*\n]+?)\*(?!\*)/g, '<em>$1</em>')
    // Doppelte Newlines = Absatz-Trennung (mit margin), einfache = Zeilenumbruch
    .replace(/\n\n+/g, '<br class="para">')
    .replace(/\n/g, '<br>');
}

function showTyping() {
  const chat = document.getElementById('chat');
  const wrap = document.createElement('div');
  wrap.id = 'typing';
  wrap.className = 'message bot typing-wrap';
  const bub = document.createElement('div');
  bub.className = 'typing-bubble';
  bub.innerHTML = '<div class="tdot"></div><div class="tdot"></div><div class="tdot"></div>';
  wrap.appendChild(bub);
  chat.appendChild(wrap);
  chat.scrollTop = chat.scrollHeight;
}
function removeTyping() { const t = document.getElementById('typing'); if (t) t.remove(); }

function updateProgress() {
  const meta = MODE_META[currentMode];
  if (!meta.showProgress) return;
  for (let i = 0; i < meta.maxQuestions; i++) {
    const el = document.getElementById('step' + i);
    if (!el) continue;
    if (i < userAnswerCount) el.className = 'progress-step done';
    else if (i === userAnswerCount) el.className = 'progress-step active';
    else el.className = 'progress-step';
  }
}

function updateCounter() {
  const pill = document.getElementById('counterPill');
  if (!currentMode) { pill.style.display = 'none'; return; }
  const meta = MODE_META[currentMode];
  if (currentMode === 'quick') {
    pill.textContent = `Frage ${Math.min(userAnswerCount + 1, meta.maxQuestions)} von max. ${meta.maxQuestions}`;
  } else if (currentMode === 'holistic') {
    pill.textContent = `Frage ${Math.min(userAnswerCount + 1, meta.maxQuestions)} von ~${meta.maxQuestions}`;
  } else {
    pill.textContent = `Frage ${Math.min(userAnswerCount + 1, meta.maxQuestions)} von max. ${meta.maxQuestions}`;
  }
  pill.style.display = 'inline-flex';
}

// ─── API ─────────────────────────────────────────────────────────────────────
async function callClaude(body) {
  if (IS_STANDALONE) {
    const key = getApiKey();
    if (!key) { showApiKeySetup(); throw new Error('API-Key fehlt'); }
    return fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'x-api-key': key,
        'anthropic-version': '2023-06-01',
        'anthropic-dangerous-direct-browser-access': 'true'
      },
      body: JSON.stringify(body)
    });
  }
  return fetch('/api/chat', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(body)
  });
}

// Unified request+render: handles 429 / 401 / network errors / API-key modal.
// Returns the bot reply text on success, or null on handled error (caller stops).
let rateLimitWarned = false;

async function requestReply(body) {
  try {
    const res = await callClaude(body);
    // Rate-Limit-Remaining merken — Warn-Bubble wird gleich nach removeTyping eingefügt
    let warnRemaining = null;
    const remainingHeader = res.headers?.get?.('x-ratelimit-remaining');
    if (!rateLimitWarned && remainingHeader) {
      const remaining = parseInt(remainingHeader, 10);
      if (!isNaN(remaining) && remaining <= 10 && remaining > 0) {
        warnRemaining = remaining;
        rateLimitWarned = true;
      }
    }
    const data = await res.json();
    removeTyping();
    if (warnRemaining !== null) {
      // Instant-Bubble (isRestore=true), damit Typewriter den Reply nicht blockiert
      addMsg('bot', `⏳ Noch **${warnRemaining} Anfragen** heute — danach greift das Tageslimit.`, true);
    }
    if (res.status === 429) {
      addMsg('bot', `⏳ ${data.message || data.error?.message || 'Tageslimit erreicht — morgen wieder.'}`);
      return null;
    }
    if (res.status === 401) {
      addMsg('bot', '⚠️ API-Key ungültig. Bitte korrekten Anthropic-Key eingeben.');
      if (IS_STANDALONE) { clearApiKey(); showApiKeySetup(); }
      return null;
    }
    if (res.status >= 400) {
      // Technischer Fehler (500, 400, etc.) — User sieht sauber, Details in Console
      console.error('[requestReply] HTTP ' + res.status, data);
      addMsg('bot', '⚠️ Technischer Fehler. Bitte versuche es gleich nochmal.');
      return null;
    }
    const text = data.content?.[0]?.text;
    if (!text) {
      console.error('[requestReply] Leere Antwort', data);
      addMsg('bot', '⚠️ Leere Antwort erhalten. Bitte nochmal versuchen.');
      return null;
    }
    return text;
  } catch (e) {
    removeTyping();
    if (e.message !== 'API-Key fehlt') {
      console.error('[requestReply] Netzwerkfehler', e);
      addMsg('bot', '⚠️ Verbindungsfehler. Bitte versuche es erneut.');
    }
    return null;
  }
}

async function initChat() {
  showTyping();
  const profile = currentMode !== 'onboarding' ? getProfile() : '';
  const hasProfile = !!(profile && profile.trim());
  const initMsg = currentMode === 'onboarding'
    ? 'Starte den Kennenlern-Check. Kurze Begrüßung (max. 1 Satz — z.B. "Bevor\'s losgeht — kurz kennenlernen."), dann direkt Frage 1 (Branche & Unternehmen in einem Satz).'
    : currentMode === 'roast'
    ? (hasProfile
        ? 'Starte. Ein Satz Begrüßung — hart aber fair — dann spiegle in 1-2 Sätzen die schwächste Stelle die du im Kontext schon erkennst, und frage genau danach. Kein generisches "Beschreib deine Marketing-Strategie" — du hast den Kontext schon.'
        : 'Starte. Ein Satz Begrüßung — hart aber fair — dann sofort: Beschreib deine Marketing-Strategie.')
    : currentMode === 'holistic'
    ? (hasProfile
        ? 'Starte die holistische Diagnose. Kurze Begrüßung, spiegle in 1-2 Sätzen was du über die Situation schon weißt, erklär dass wir uns durch ~30 Fragen arbeiten und am Ende ein 90-Tage-Plan steht. Dann direkt Frage 1 — aber wenn sie durch den Kontext schon beantwortet ist, bestätige die Info kurz und spring zur nächsten offenen Frage.'
        : 'Starte die holistische Diagnose. Kurze Begrüßung (1–2 Sätze) — erklär kurz dass wir uns durch ~30 Fragen arbeiten und am Ende ein 90-Tage-Plan steht. Dann direkt Frage 1 (Kontext).')
    : (hasProfile
        ? 'Starte. Kurze Begrüßung, spiegle in 1-2 Sätzen was du über die Situation schon weißt, und stelle dann eine spezifische erste Frage die direkt auf den Kontext zugeschnitten ist. KEIN generisches "Was ist gerade dein größtes Marketing-Ding?" — die Frage muss zeigen dass du den Kontext gelesen hast.'
        : 'Starte. Kurze Begrüßung (1 Satz) — direkt, kein Aufwärmen — dann sofort: Was ist gerade dein größtes Marketing-Ding? (oder ähnlich)');

  const systemPrompt = buildSystemPrompt(currentMode, userAnswerCount, profile);
  const reply = await requestReply({
    model: 'claude-sonnet-4-6',
    max_tokens: currentMode === 'holistic' ? 2000 : 1000,
    system: systemPrompt,
    messages: [{ role: 'user', content: initMsg }]
  });
  if (reply === null) return;
  messages.push({ role: 'user', content: initMsg });
  messages.push({ role: 'assistant', content: reply });
  addMsg('bot', reply);
  saveSession(currentMode, messages, userAnswerCount);
}

async function fetchReply() {
  showTyping();
  const profile = currentMode !== 'onboarding' ? getProfile() : '';
  const systemPrompt = buildSystemPrompt(currentMode, userAnswerCount, profile);
  const reply = await requestReply({
    model: 'claude-sonnet-4-6',
    max_tokens: currentMode === 'holistic' ? 2500 : 1500,
    system: systemPrompt,
    messages
  });
  if (reply === null) return;
  messages.push({ role: 'assistant', content: reply });
  addMsg('bot', reply);
  updateProgress();
  updateCounter();
  saveSession(currentMode, messages, userAnswerCount);
  // Input wird durch addMsg() nach Typewriter re-enabled
}

async function send() {
  const input = document.getElementById('input');
  const btn = document.getElementById('sendBtn');
  if (btn.disabled || isTyping) return;
  const text = input.value.trim();
  if (!text || !currentMode) return;
  input.value = '';
  input.style.height = 'auto';
  clearDraft(currentMode);
  setInputEnabled(false);
  addMsg('user', text);
  messages.push({ role: 'user', content: text });
  userAnswerCount++;
  updateProgress();
  updateCounter();
  saveSession(currentMode, messages, userAnswerCount);
  await fetchReply();
}

// ─── EXPORT ──────────────────────────────────────────────────────────────────
function exportCurrent() {
  if (!currentMode || messages.length === 0) return;
  const meta = MODE_META[currentMode];
  const lastBot = [...messages].reverse().find(m => m.role === 'assistant');
  if (!lastBot) return;

  const header = `# ${meta.title}\n_Marketing Co-Pilot · ${new Date().toLocaleDateString('de-DE', { year: 'numeric', month: 'long', day: 'numeric' })}_\n\n---\n\n`;
  const content = header + lastBot.content;

  const blob = new Blob([content], { type: 'text/markdown;charset=utf-8' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = meta.exportFileName;
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  URL.revokeObjectURL(url);
}

function copyLast() {
  const lastBot = [...messages].reverse().find(m => m.role === 'assistant');
  if (!lastBot) return;
  navigator.clipboard.writeText(lastBot.content).then(() => {
    const btns = document.querySelectorAll('.export-btn');
    btns.forEach(b => {
      if (b.textContent.includes('Kopieren')) {
        const orig = b.textContent;
        b.textContent = '✓ Kopiert!';
        setTimeout(() => { b.textContent = orig; }, 1800);
      }
    });
  });
}

// ─── INPUT HANDLERS ──────────────────────────────────────────────────────────
const inputEl = document.getElementById('input');
const DRAFT_KEY = 'ma_drafts_v1';
let draftSaveTimer = null;

function getDrafts() { try { return JSON.parse(safeGetItem(DRAFT_KEY)) || {}; } catch { return {}; } }
function saveDraft(mode, value) {
  if (!mode) return;
  clearTimeout(draftSaveTimer);
  draftSaveTimer = setTimeout(() => {
    const drafts = getDrafts();
    if (value) drafts[mode] = value;
    else delete drafts[mode];
    safeSetItem(DRAFT_KEY, JSON.stringify(drafts));
  }, 300);
}
function restoreDraft(mode) {
  if (!mode) return;
  const drafts = getDrafts();
  const val = drafts[mode] || '';
  inputEl.value = val;
  if (val) {
    inputEl.style.height = 'auto';
    inputEl.style.height = Math.min(inputEl.scrollHeight, 140) + 'px';
  }
}
function clearDraft(mode) {
  if (!mode) return;
  const drafts = getDrafts();
  delete drafts[mode];
  safeSetItem(DRAFT_KEY, JSON.stringify(drafts));
}

inputEl.addEventListener('input', () => {
  inputEl.style.height = 'auto';
  inputEl.style.height = Math.min(inputEl.scrollHeight, 140) + 'px';
  saveDraft(currentMode, inputEl.value);
});
inputEl.addEventListener('keydown', e => {
  if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); send(); }
});
</script>
