<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Marketing Co-Pilot</title>
<link rel="icon" type="image/png" href="./Favicon.png">
<link rel="stylesheet" href="./co-pilot-design-system.css">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

/* Keyboard-only Focus-Ring (WCAG 2.4.7). Maus-Klicks zeigen keinen Ring — nur Tab-Navigation. */
:focus { outline: none; }
:focus-visible {
  outline: var(--cp-border) solid var(--cp-orange);
  outline-offset: 2px;
}
textarea#input:focus-visible { outline: none; } /* Input hat eigenen Glow-Stil */

body {
  font-family: var(--cp-font-ui);
  background: var(--cp-navy);
  color: var(--cp-off-white);
  min-height: 100vh;
  height: 100vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  -webkit-font-smoothing: antialiased;
}

/* Faint pixel grid — applied via pseudo so it never disturbs layout */
body::before {
  content: '';
  position: fixed; inset: 0;
  background-image:
    linear-gradient(var(--cp-line) var(--px), transparent var(--px)),
    linear-gradient(90deg, var(--cp-line) var(--px), transparent var(--px));
  background-size: clamp(20px, 3vw, 28px) clamp(20px, 3vw, 28px);
  opacity: 0.18;
  pointer-events: none;
  z-index: 0;
  mask-image: radial-gradient(ellipse at center, #000 20%, transparent 75%);
}

/* ═══════════════════════════════════════════════════════════════════════════
   SELECTOR VIEW
   ═══════════════════════════════════════════════════════════════════════════ */
#selectorView {
  position: fixed;
  inset: 0;
  z-index: 100;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: clamp(32px, 6vw, 64px) clamp(16px, 4vw, 32px) clamp(32px, 5vw, 48px);
  overflow-y: auto;
  background: var(--cp-navy);
}

.select-header {
  text-align: center;
  margin-bottom: clamp(28px, 4vw, 44px);
  width: 100%;
  max-width: 900px;
  position: relative;
  z-index: 1;
}

.select-logo {
  display: flex;
  justify-content: center;
  margin-bottom: clamp(20px, 3vw, 32px);
  filter: drop-shadow(0 0 40px rgba(255,145,77,0.18));
}

/* Pixel CO-PILOT monitor plate */
.cp-monitor {
  display: inline-flex;
  flex-direction: column;
  align-items: stretch;
  gap: 6px;
  padding: clamp(10px, 1.4vw, 14px) clamp(12px, 1.6vw, 16px);
  background: var(--cp-orange);
  border: var(--cp-border-chunky) solid var(--cp-black);
  border-radius: var(--cp-radius-card);
  box-shadow:
    var(--px) var(--px) 0 var(--cp-black),
    var(--px-3) var(--px-3) 0 var(--cp-orange-deep);
}
.cp-monitor__icon-row {
  display: flex;
}
.cp-monitor__icon {
  display: grid;
  place-items: center;
  width: clamp(28px, 3.2vw, 38px);
  height: clamp(28px, 3.2vw, 38px);
  background: var(--cp-off-white);
  border: var(--cp-border) solid var(--cp-black);
  color: var(--cp-black);
  border-radius: 2px;
}
.cp-monitor__icon svg {
  width: 55%;
  height: 55%;
  shape-rendering: crispEdges;
}
.cp-monitor__label {
  display: inline-flex;
  align-items: center;
  padding: clamp(6px, 0.9vw, 9px) clamp(10px, 1.4vw, 16px);
  background: var(--cp-off-white);
  border: var(--cp-border) solid var(--cp-black);
  border-radius: 2px;
  font-family: var(--cp-font-display);
  font-size: clamp(0.875rem, 1.8vw, 1.375rem);
  color: var(--cp-black);
  letter-spacing: 0.06em;
  white-space: nowrap;
  line-height: 1;
}
.cp-monitor__label::before {
  content: '> ';
  color: var(--cp-orange-deep);
  font-family: var(--cp-font-mono);
  font-size: 1.3em;
  margin-right: 0.25em;
  line-height: 0;
  transform: translateY(0.05em);
}

.select-header h1 {
  font-family: var(--cp-font-display);
  font-size: clamp(1.25rem, 3.2vw, 1.75rem);
  color: var(--cp-orange);
  margin-bottom: 14px;
  letter-spacing: 0.02em;
  line-height: 1.25;
}
.select-header h1::before {
  content: '> ';
  color: var(--cp-orange);
  font-family: var(--cp-font-mono);
}

.select-header p {
  font-family: var(--cp-font-mono);
  font-size: clamp(1rem, 1.6vw, 1.25rem);
  color: #D8DDE2;
  line-height: 1.4;
  max-width: 560px;
  margin: 0 auto;
}

.logout-btn {
  margin-top: 20px;
  background: transparent;
  border: var(--cp-border) solid var(--cp-orange);
  border-radius: var(--cp-radius-chip);
  padding: 9px 18px;
  font-family: var(--cp-font-display);
  font-size: 0.625rem;
  letter-spacing: 0.08em;
  color: var(--cp-orange);
  cursor: pointer;
  text-transform: uppercase;
  transition: background var(--cp-dur) var(--cp-ease), color var(--cp-dur) var(--cp-ease);
}
.logout-btn:hover { background: var(--cp-orange); color: var(--cp-black); }

/* Mode grid */
.mode-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: clamp(16px, 2.5vw, 24px);
  width: 100%;
  max-width: 1040px;
  position: relative;
  z-index: 1;
}

.mode-card {
  background: var(--cp-navy-deep);
  border: var(--cp-border-chunky) solid var(--cp-orange);
  border-radius: var(--cp-radius-card);
  padding: clamp(20px, 2.5vw, 28px) clamp(18px, 2.2vw, 24px);
  cursor: pointer;
  transition: transform var(--cp-dur) var(--cp-ease), box-shadow var(--cp-dur) var(--cp-ease);
  box-shadow: var(--cp-shadow-pixel);
  position: relative;
  display: flex;
  flex-direction: column;
  min-height: 260px;
}
.mode-card:hover {
  transform: translate(-2px, -2px);
  box-shadow: var(--cp-shadow-pixel-lg);
}
.mode-card:active {
  transform: translate(1px, 1px);
  box-shadow: var(--px) var(--px) 0 var(--cp-black);
}

.mode-card.fix {
  border-color: var(--cp-danger, #FF6B6B);
  box-shadow:
    var(--px) var(--px) 0 var(--cp-black),
    var(--px-2) var(--px-2) 0 var(--cp-danger-deep, #C43838);
}
.mode-card.fix:hover {
  box-shadow:
    var(--px) var(--px) 0 var(--cp-black),
    var(--px-3) var(--px-3) 0 var(--cp-danger-deep, #C43838);
}

.mode-card.roast {
  border-color: var(--cp-cool, #5BA3D0);
  box-shadow:
    var(--px) var(--px) 0 var(--cp-black),
    var(--px-2) var(--px-2) 0 var(--cp-cool-deep, #3D7DA3);
}
.mode-card.roast:hover {
  box-shadow:
    var(--px) var(--px) 0 var(--cp-black),
    var(--px-3) var(--px-3) 0 var(--cp-cool-deep, #3D7DA3);
}

.mode-icon {
  font-size: 32px;
  margin-bottom: 14px;
  line-height: 1;
  filter: drop-shadow(0 0 8px rgba(255,145,77,0.3));
}
.mode-card.fix .mode-icon { filter: drop-shadow(0 0 8px rgba(255,107,107,0.35)); }
.mode-card.roast .mode-icon { filter: drop-shadow(0 0 8px rgba(91,163,208,0.4)); }

.mode-tag {
  font-family: var(--cp-font-display);
  font-size: 0.5625rem;
  letter-spacing: 0.1em;
  color: var(--cp-orange);
  margin-bottom: 10px;
  text-transform: uppercase;
  line-height: 1.2;
}
.mode-card.fix .mode-tag { color: var(--cp-danger, #FF6B6B); }
.mode-card.roast .mode-tag { color: var(--cp-cool, #5BA3D0); }

.mode-title {
  font-family: var(--cp-font-display);
  font-size: clamp(0.875rem, 1.4vw, 1rem);
  color: var(--cp-off-white);
  margin-bottom: 12px;
  line-height: 1.25;
  letter-spacing: 0.02em;
}

.mode-desc {
  font-family: var(--cp-font-ui);
  font-size: 0.875rem;
  color: #D8DDE2;
  line-height: 1.55;
  flex-grow: 1;
}

.mode-meta {
  font-family: var(--cp-font-mono);
  font-size: 0.9375rem;
  color: #9AA3AC;
  margin-top: 14px;
  padding-top: 12px;
  border-top: 1px dashed rgba(255,145,77,0.3);
  letter-spacing: 0.02em;
}
.mode-card.fix .mode-meta { border-top-color: rgba(255,107,107,0.3); }
.mode-card.roast .mode-meta { border-top-color: rgba(91,163,208,0.35); }

.resume-link {
  margin-top: 10px;
  display: inline-block;
  font-family: var(--cp-font-mono);
  font-size: 0.9375rem;
  color: var(--cp-orange);
  cursor: pointer;
  padding: 6px 12px;
  background: rgba(255,145,77,0.1);
  border: var(--cp-border) solid var(--cp-orange);
  border-radius: var(--cp-radius-chip);
  transition: background var(--cp-dur) var(--cp-ease);
}
.resume-link:hover { background: rgba(255,145,77,0.2); }
.mode-card.fix .resume-link {
  color: var(--cp-danger, #FF6B6B);
  background: rgba(255,107,107,0.1);
  border-color: var(--cp-danger, #FF6B6B);
}
.mode-card.fix .resume-link:hover { background: rgba(255,107,107,0.2); }
.mode-card.roast .resume-link {
  color: var(--cp-cool, #5BA3D0);
  background: rgba(91,163,208,0.1);
  border-color: var(--cp-cool, #5BA3D0);
}
.mode-card.roast .resume-link:hover { background: rgba(91,163,208,0.2); }

/* ═══════════════════════════════════════════════════════════════════════════
   CHAT VIEW
   ═══════════════════════════════════════════════════════════════════════════ */
#chatView {
  display: none;
  flex-direction: column;
  height: 100vh;
  position: relative;
  z-index: 1;
}

.chat-header {
  padding: 12px clamp(14px, 2.5vw, 22px);
  background: var(--cp-navy-deep);
  border-bottom: var(--cp-border-chunky) solid var(--cp-orange);
  display: flex;
  align-items: center;
  gap: 12px;
  flex-shrink: 0;
  z-index: 10;
  box-shadow: 0 var(--px) 0 var(--cp-orange-deep);
}
#chatView.mode-roast .chat-header {
  border-bottom-color: var(--cp-cool, #5BA3D0);
  box-shadow: 0 var(--px) 0 var(--cp-cool-deep, #3D7DA3);
}
#chatView.mode-fix .chat-header {
  border-bottom-color: var(--cp-danger, #FF6B6B);
  box-shadow: 0 var(--px) 0 var(--cp-danger-deep, #C43838);
}

.back-btn {
  height: 38px;
  padding: 0 14px;
  background: transparent;
  border: var(--cp-border) solid var(--cp-orange);
  border-radius: var(--cp-radius-chip);
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 6px;
  font-family: var(--cp-font-display);
  font-size: 0.5625rem;
  letter-spacing: 0.06em;
  color: var(--cp-orange);
  text-transform: uppercase;
  transition: background var(--cp-dur) var(--cp-ease), color var(--cp-dur) var(--cp-ease);
  flex-shrink: 0;
}
.back-btn:hover { background: var(--cp-orange); color: var(--cp-black); }

.header-info { flex: 1; min-width: 0; }
.header-mode {
  font-family: var(--cp-font-display);
  font-size: 0.5rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--cp-orange);
  line-height: 1;
  margin-bottom: 4px;
}
#chatView.mode-roast .header-mode { color: var(--cp-cool, #5BA3D0); }
#chatView.mode-fix .header-mode { color: var(--cp-danger, #FF6B6B); }

.header-title {
  font-family: var(--cp-font-display);
  font-size: clamp(0.6875rem, 1.2vw, 0.8125rem);
  color: var(--cp-off-white);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  letter-spacing: 0.03em;
  line-height: 1.2;
}

.counter-pill {
  padding: 5px 10px;
  background: transparent;
  color: var(--cp-orange);
  border: var(--cp-border) solid var(--cp-orange);
  border-radius: var(--cp-radius-chip);
  font-family: var(--cp-font-mono);
  font-size: 0.9375rem;
  white-space: nowrap;
  letter-spacing: 0.02em;
}
#chatView.mode-roast .counter-pill {
  color: var(--cp-cool, #5BA3D0);
  border-color: var(--cp-cool, #5BA3D0);
}
#chatView.mode-fix .counter-pill {
  color: var(--cp-danger, #FF6B6B);
  border-color: var(--cp-danger, #FF6B6B);
}

.header-logo {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  padding-left: 12px;
  border-left: 1px dashed rgba(255,145,77,0.4);
  margin-left: 4px;
}
.header-logo-icon {
  width: 32px;
  height: 32px;
  border: var(--cp-border) solid var(--cp-orange);
  border-radius: var(--cp-radius-chip);
  overflow: hidden;
  background: var(--cp-orange);
}
.header-logo-icon img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* Progress */
.progress-wrap {
  display: flex;
  gap: 4px;
  padding: 10px clamp(14px, 2.5vw, 22px);
  flex-shrink: 0;
  background: var(--cp-navy-deep);
  border-bottom: var(--cp-border) solid rgba(255,145,77,0.25);
}
.progress-step {
  height: 4px;
  flex: 1;
  background: rgba(255,145,77,0.2);
  border-radius: 0;
  transition: background 0.3s ease;
}
.progress-step.done { background: var(--cp-orange); }
.progress-step.active {
  background: var(--cp-orange-soft);
  animation: stepPulse 1.4s ease infinite;
}
@keyframes stepPulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.55; }
}
#chatView.mode-roast .progress-step { background: rgba(91,163,208,0.15); border-color: rgba(91,163,208,0.2); }
#chatView.mode-roast .progress-step.done { background: var(--cp-cool, #5BA3D0); }
#chatView.mode-roast .progress-step.active { background: #7FB8DB; border-color: var(--cp-cool, #5BA3D0); }
#chatView.mode-fix .progress-step { background: rgba(255,107,107,0.15); border-color: rgba(255,107,107,0.2); }
#chatView.mode-fix .progress-step.done { background: var(--cp-danger, #FF6B6B); }
#chatView.mode-fix .progress-step.active { background: #FF9090; border-color: var(--cp-danger, #FF6B6B); }

/* Chat stream — terminal style, no bubbles */
#chat {
  flex: 1;
  overflow-y: auto;
  padding: clamp(18px, 2.5vw, 28px) clamp(16px, 3vw, 32px);
  display: flex;
  flex-direction: column;
  gap: 14px;
  scroll-behavior: smooth;
  font-family: var(--cp-font-mono);
}
#chat::-webkit-scrollbar { width: 6px; }
#chat::-webkit-scrollbar-track { background: transparent; }
#chat::-webkit-scrollbar-thumb { background: var(--cp-orange); }

.message { display: block; animation: msgIn 0.2s ease; }
@keyframes msgIn { from { opacity: 0; } to { opacity: 1; } }

.bubble {
  max-width: 100%;
  padding: 0;
  background: none;
  border: none;
  font-family: var(--cp-font-mono);
  font-size: clamp(1.0625rem, 1.8vw, 1.25rem);
  line-height: 1.55;
  letter-spacing: 0.005em;
  display: block;
  color: var(--cp-off-white);
  word-break: break-word;
}

/* User line: orange with prompt caret */
.message.user .bubble {
  color: var(--cp-orange);
}
.message.user .bubble::before {
  content: '> ';
  color: var(--cp-orange);
  font-weight: 700;
}

/* Bot line: off-white, indented slightly, no prefix */
.message.bot .bubble { color: var(--cp-off-white); }
#chatView.mode-roast .message.bot .bubble { color: #D8ECF6; }
#chatView.mode-fix .message.bot .bubble { color: #FFE4E4; }

/* Typewriter cursor — blinking pixel block (auf Chat-Bubble UND Hero-H1) */
.bubble.typing::after,
#heroLine.typing::after {
  content: '▊';
  display: inline-block;
  margin-left: 2px;
  color: var(--cp-orange);
  animation: cursorBlink 1s steps(2) infinite;
  font-weight: 700;
  transform: translateY(-1px);
}
#chatView.mode-roast .bubble.typing::after { color: var(--cp-cool, #5BA3D0); }
#chatView.mode-fix .bubble.typing::after { color: var(--cp-danger, #FF6B6B); }
@keyframes cursorBlink {
  0%, 50% { opacity: 1; }
  51%, 100% { opacity: 0; }
}

/* Absatz-Break im Chat-Text — mehr Luft als normaler Zeilenumbruch */
.bubble br.para { display: block; margin-bottom: 0.7em; }

/* Markdown Headings — orange, unterschieden durch Größe */
.bubble .md-h1 {
  display: inline-block;
  font-family: var(--cp-font-display);
  font-size: 1.1em;
  color: var(--cp-orange);
  letter-spacing: 0.02em;
  margin: 0.3em 0 0.2em;
}
.bubble .md-h2 {
  display: inline-block;
  font-family: var(--cp-font-display);
  font-size: 1em;
  color: var(--cp-orange);
  letter-spacing: 0.02em;
  margin: 0.25em 0 0.15em;
}
.bubble .md-h3 {
  display: inline-block;
  font-weight: 700;
  color: var(--cp-orange);
  margin: 0.2em 0 0.1em;
}
#chatView.mode-roast .md-h1,
#chatView.mode-roast .md-h2,
#chatView.mode-roast .md-h3 { color: var(--cp-cool, #5BA3D0); }
#chatView.mode-fix .md-h1,
#chatView.mode-fix .md-h2,
#chatView.mode-fix .md-h3 { color: var(--cp-danger, #FF6B6B); }

/* Listen — Bullet (-) und Nummeriert (1.) */
.bubble .md-li,
.bubble .md-li-num {
  display: inline-block;
  padding-left: 1.2em;
  position: relative;
}
.bubble .md-li::before {
  content: '›';
  position: absolute;
  left: 0.2em;
  color: var(--cp-orange);
  font-weight: 700;
}
.bubble .md-li-num::before {
  content: attr(data-n);
  position: absolute;
  left: 0;
  color: var(--cp-orange);
  font-weight: 700;
  font-family: var(--cp-font-mono);
}
#chatView.mode-roast .md-li::before,
#chatView.mode-roast .md-li-num::before { color: var(--cp-cool, #5BA3D0); }
#chatView.mode-fix .md-li::before,
#chatView.mode-fix .md-li-num::before { color: var(--cp-danger, #FF6B6B); }

.bubble strong { font-weight: 700; color: var(--cp-orange); }
#chatView.mode-roast .message.bot .bubble strong { color: var(--cp-cool, #5BA3D0); }
#chatView.mode-fix .message.bot .bubble strong { color: var(--cp-danger, #FF6B6B); }
.bubble em { font-style: italic; color: #FFCDA8; }

/* Divider between turns — subtle dashed line */
.message + .message { border-top: 1px dashed rgba(255,145,77,0.12); padding-top: 14px; margin-top: 0; }

/* Export box — terminal mini-card inside bot bubble */
.export-box {
  background: var(--cp-navy-deep);
  border: var(--cp-border) solid var(--cp-orange);
  border-radius: 2px;
  padding: 12px 14px;
  margin-top: 12px;
}
#chatView.mode-roast .export-box { border-color: var(--cp-cool, #5BA3D0); }
#chatView.mode-fix .export-box { border-color: var(--cp-danger, #FF6B6B); }
.export-box h4 {
  font-family: var(--cp-font-display);
  font-size: 0.6875rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--cp-orange);
  margin-bottom: 12px;
}
#chatView.mode-roast .export-box h4 { color: var(--cp-cool, #5BA3D0); }
#chatView.mode-fix .export-box h4 { color: var(--cp-danger, #FF6B6B); }

.export-btn {
  background: transparent;
  border: var(--cp-border) solid var(--cp-orange);
  color: var(--cp-orange);
  padding: 9px 14px;
  border-radius: var(--cp-radius-chip);
  cursor: pointer;
  font-family: var(--cp-font-display);
  font-size: 0.5625rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  transition: background var(--cp-dur) var(--cp-ease), color var(--cp-dur) var(--cp-ease);
  display: inline-flex;
  align-items: center;
  gap: 6px;
  margin-right: 6px;
}
.export-btn:hover { background: var(--cp-orange); color: var(--cp-black); }
.export-btn.primary {
  background: var(--cp-orange);
  color: var(--cp-black);
  border-color: var(--cp-black);
  box-shadow: var(--px) var(--px) 0 var(--cp-black);
}
.export-btn.primary:hover { background: var(--cp-orange-soft); }
#chatView.mode-roast .export-btn {
  border-color: var(--cp-cool, #5BA3D0);
  color: var(--cp-cool, #5BA3D0);
}
#chatView.mode-roast .export-btn:hover { background: var(--cp-cool, #5BA3D0); color: var(--cp-off-white); }
#chatView.mode-roast .export-btn.primary {
  background: var(--cp-cool, #5BA3D0);
  color: var(--cp-off-white);
  border-color: var(--cp-black);
}
#chatView.mode-fix .export-btn {
  border-color: var(--cp-danger, #FF6B6B);
  color: var(--cp-danger, #FF6B6B);
}
