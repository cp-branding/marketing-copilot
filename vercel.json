{
  "rewrites": [
    { "source": "/login", "destination": "/login.html" }
  ],
  "routes": [
    {
      "src": "/((?!api|login|_vercel).*)",
      "has": [{ "type": "cookie", "key": "mk_session" }],
      "dest": "/public/$1"
    },
    {
      "src": "/((?!api|login|_vercel).*)",
      "dest": "/login"
    }
  ]
}
